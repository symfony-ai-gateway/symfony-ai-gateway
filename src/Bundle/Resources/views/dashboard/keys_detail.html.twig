{% extends "@AIGateway/dashboard/base.html.twig" %}
{% import "@AIGateway/dashboard/base.html.twig" as dash %}

{% block title %}AIGateway Dashboard — Key {{ key.name }}{% endblock %}

{% block head %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
{% endblock %}

{% block content %}
<div style="display:flex;justify-content:space-between;align-items:center">
    <h1 class="page-title">Key: {{ key.name }}</h1>
    <div style="display:flex;gap:12px;align-items:center">
        {% if key.enabled %}
        <span class="badge badge-green">active</span>
        <a href="{{ dash.turl('/dashboard/keys/' ~ key.id ~ '/edit', dashboard_token|default('')) }}" class="btn btn-primary" style="padding:6px 16px;font-size:13px">Edit</a>
        <form method="POST" action="{{ dash.turl('/dashboard/keys/' ~ key.id ~ '/revoke', dashboard_token|default('')) }}" style="display:inline" onsubmit="return confirm('Revoke this key? It cannot be undone.')">
            <button type="submit" class="btn btn-danger" style="padding:6px 16px;font-size:13px">Revoke</button>
        </form>
        {% else %}
        <span class="badge badge-red">revoked</span>
        <a href="{{ dash.turl('/dashboard/keys/' ~ key.id ~ '/edit', dashboard_token|default('')) }}" class="btn btn-primary" style="padding:6px 16px;font-size:13px">Edit</a>
        {% endif %}
    </div>
</div>

{# ── 1. Stats cards ── #}
<div class="grid grid-4">
    <div class="card"><h3>Requests</h3><div class="value blue">{{ key_stats.requests|number_format }}</div></div>
    <div class="card"><h3>Tokens</h3><div class="value green">{{ key_stats.tokens|number_format }}</div></div>
    <div class="card"><h3>Cost</h3><div class="value yellow">${{ key_stats.cost|number_format(4) }}</div></div>
    <div class="card"><h3>Errors</h3><div class="value {% if key_stats.errors > 0 %}red{% else %}green{% endif %}">{{ key_stats.errors }}</div></div>
</div>

{# ── 2. Info + Usage Today ── #}
<div class="grid grid-2">
    <div class="card">
        <h3>Details</h3>
        <dl class="def-list">
            <dt>ID</dt><dd class="mono">{{ key.id }}</dd>
            <dt>Prefix</dt><dd class="mono">{{ key.tokenPrefix }}...</dd>
            <dt>Team</dt>
            <dd>{% if team %}<a href="{{ dash.turl('/dashboard/teams/' ~ team.id, dashboard_token|default('')) }}">{{ team.name }}</a>{% else %}<span style="color:var(--text2)">none (standalone)</span>{% endif %}</dd>
            <dt>Enabled</dt><dd>{{ key.enabled ? 'yes' : 'no' }}</dd>
            <dt>Expired</dt><dd>{{ key.isExpired() ? 'yes' : 'no' }}</dd>
            <dt>Created</dt><dd>{{ key.createdAt|date('Y-m-d H:i:s') }}</dd>
        </dl>
    </div>
    <div class="card">
        <h3>Usage Today</h3>
        {% if usage_today %}
        <dl class="def-list">
            <dt>Requests</dt><dd>{{ usage_today.requests }}</dd>
            <dt>Tokens</dt><dd>{{ usage_today.tokens|number_format }}</dd>
            <dt>Cost</dt><dd style="color:var(--yellow)">${{ usage_today.costUsd|number_format(6) }}</dd>
        </dl>
        {% else %}
        <p style="color:var(--text2)">No usage recorded today.</p>
        {% endif %}
        {% if team and team_stats is defined and team_stats %}
        <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border)">
            <span style="color:var(--text2);font-size:12px">Share of team cost</span>
            <div style="font-size:24px;font-weight:700;color:var(--accent2)">{{ key_share_pct|number_format(1) }}%</div>
            <a href="{{ dash.turl('/dashboard/teams/' ~ team.id, dashboard_token|default('')) }}" style="font-size:12px">View team →</a>
        </div>
        {% endif %}
    </div>
</div>

{# ── 3. Daily chart (stacked bar by model) ── #}
{% set stacked_dates = daily_dates|default([]) %}
{% set stacked_ds = daily_model_datasets|default([]) %}
{% if stacked_dates|length > 0 and stacked_ds|length > 0 %}
<div class="section">
    <h2>Usage Over Time (30 days)</h2>
    <div class="card"><canvas id="chartDaily" height="100"></canvas></div>
</div>
{% endif %}

{# ── 4. Doughnuts: Tokens / Cost / Requests by Model ── #}
{% set mb = model_breakdown|default([]) %}
{% if mb|length > 0 %}
<div class="section">
    <h2>Breakdown by Model</h2>
    <div class="grid grid-3">
        <div class="card"><h3>Tokens by Model</h3><canvas id="chartKTokMod" height="160"></canvas></div>
        <div class="card"><h3>Cost by Model</h3><canvas id="chartKCostMod" height="160"></canvas></div>
        <div class="card"><h3>Requests by Model</h3><canvas id="chartKReqMod" height="160"></canvas></div>
    </div>
</div>
{% endif %}

{# ── 5. Breakdown table: Models ── #}
{% if mb|length > 0 %}
<div class="section">
    <h2>Models</h2>
    <div class="card" style="padding:0;overflow:hidden">
        <table>
            <thead><tr><th>Model</th><th>Requests</th><th>Tokens</th><th>Cost</th></tr></thead>
            <tbody>
            {% for m in mb %}
            <tr>
                <td><a href="{{ dash.turl('/dashboard/models/' ~ m.model_alias, dashboard_token|default('')) }}"><strong>{{ m.model_alias }}</strong></a></td>
                <td>{{ m.requests|number_format }}</td>
                <td>{{ m.tokens|number_format }}</td>
                <td style="color:var(--yellow)">${{ m.cost|number_format(4) }}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{# ── 6. Recent Requests ── #}
{% set rl = recent_logs|default([]) %}
{% if rl|length > 0 %}
<div class="section">
    <h2>Recent Requests ({{ key_stats.requests|number_format }} total)</h2>
    <div class="card" style="padding:0;overflow:hidden">
        <table>
            <thead><tr><th>Time</th><th>Model</th><th>Provider</th><th>Tokens</th><th>Cost</th><th>Duration</th><th>Status</th></tr></thead>
            <tbody>
            {% for log in rl %}
            <tr>
                <td class="mono" style="font-size:12px">{{ log.created_at|date('Y-m-d H:i') }}</td>
                <td><a href="{{ dash.turl('/dashboard/models/' ~ log.model_alias, dashboard_token|default('')) }}">{{ log.model_alias }}</a></td>
                <td><a href="{{ dash.turl('/dashboard/providers/' ~ log.provider, dashboard_token|default('')) }}">{{ log.provider }}</a></td>
                <td>{{ log.total_tokens|number_format }} <span style="color:var(--text2);font-size:12px">({{ log.prompt_tokens }}↑ {{ log.completion_tokens }}↓)</span></td>
                <td style="color:var(--yellow)">${{ log.cost_usd|number_format(6) }}</td>
                <td>{{ log.duration_ms|number_format(1) }}ms</td>
                <td>{% if log.cached %}<span class="badge badge-green">cached</span>{% elseif log.status_code >= 400 %}<span class="badge badge-red">{{ log.status_code }}</span>{% else %}<span class="badge badge-green">{{ log.status_code }}</span>{% endif %}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{# ── 7. Rules ── #}
<div class="section">
    <h2>Effective Rules {% if team %}<span style="color:var(--text2);font-size:14px;font-weight:normal">(what actually applies)</span>{% endif %}</h2>
    <div class="card">
        <dl class="def-list">
            <dt>Budget / Day</dt><dd>{% if effective_rules.budgetPerDay is not null %}${{ effective_rules.budgetPerDay|number_format(2) }}{% else %}<span style="color:var(--text2)">unlimited</span>{% endif %}</dd>
            <dt>Budget / Month</dt><dd>{% if effective_rules.budgetPerMonth is not null %}${{ effective_rules.budgetPerMonth|number_format(2) }}{% else %}<span style="color:var(--text2)">unlimited</span>{% endif %}</dd>
            <dt>Rate Limit</dt><dd>{% if effective_rules.rateLimitPerMinute is not null %}{{ effective_rules.rateLimitPerMinute }} req/min{% else %}<span style="color:var(--text2)">unlimited</span>{% endif %}</dd>
            <dt>Models</dt><dd>{% if effective_rules.models is not null %}{{ effective_rules.models|join(', ') }}{% else %}all{% endif %}</dd>
        </dl>
    </div>
</div>

{% if team %}
<div class="section">
    <h2>Breakdown</h2>
    <div class="grid grid-2">
        <div class="card">
            <h3>Team Rules <span style="color:var(--text2);font-weight:normal">({{ team.name }})</span></h3>
            <dl class="def-list">
                <dt>Budget / Day</dt><dd>{{ team.rules.budgetPerDay is not null ? '$' ~ team.rules.budgetPerDay|number_format(2) : '<span style="color:var(--text2)">unlimited</span>' }}</dd>
                <dt>Budget / Month</dt><dd>{{ team.rules.budgetPerMonth is not null ? '$' ~ team.rules.budgetPerMonth|number_format(2) : '<span style="color:var(--text2)">unlimited</span>' }}</dd>
                <dt>Rate Limit</dt><dd>{{ team.rules.rateLimitPerMinute is not null ? team.rules.rateLimitPerMinute ~ ' req/min' : '<span style="color:var(--text2)">unlimited</span>' }}</dd>
                <dt>Models</dt><dd>{{ team.rules.models is not null ? team.rules.models|join(', ') : 'all' }}</dd>
            </dl>
        </div>
        <div class="card">
            <h3>Key Overrides {% if not has_own_overrides %}<span style="color:var(--text2);font-weight:normal">(inherits everything)</span>{% endif %}</h3>
            {% if has_own_overrides %}
            <dl class="def-list">
                <dt>Budget / Day</dt><dd>{{ key.overrides.budgetPerDay is not null ? '$' ~ key.overrides.budgetPerDay|number_format(2) : '<span style="color:var(--text2)">inherits</span>' }}</dd>
                <dt>Budget / Month</dt><dd>{{ key.overrides.budgetPerMonth is not null ? '$' ~ key.overrides.budgetPerMonth|number_format(2) : '<span style="color:var(--text2)">inherits</span>' }}</dd>
                <dt>Rate Limit</dt><dd>{{ key.overrides.rateLimitPerMinute is not null ? key.overrides.rateLimitPerMinute ~ ' req/min' : '<span style="color:var(--text2)">inherits</span>' }}</dd>
                <dt>Models</dt><dd>{{ key.overrides.models is not null ? key.overrides.models|join(', ') : '<span style="color:var(--text2)">inherits</span>' }}</dd>
            </dl>
            {% else %}
            <p style="color:var(--text2)">No overrides — this key inherits all rules from team <strong>{{ team.name }}</strong>.</p>
            {% endif %}
        </div>
    </div>
</div>
{% endif %}
{% endblock %}

{% block scripts %}
<script>
const colors = ['#6366f1','#3b82f6','#22c55e','#f59e0b','#ef4444','#8b5cf6','#ec4899','#14b8a6','#f97316','#a855f7'];

{% set stacked_dates = daily_dates|default([]) %}
{% set stacked_ds = daily_model_datasets|default([]) %}
{% if stacked_dates|length > 0 and stacked_ds|length > 0 %}
new Chart(document.getElementById('chartDaily'), {
    type: 'bar',
    data: {
        labels: {{ stacked_dates|json_encode(15)|raw }},
        datasets: [
            {% for ds in stacked_ds %}
            { label: {{ ds.label|json_encode(15)|raw }}, data: {{ ds.data|json_encode(15)|raw }}, backgroundColor: colors[{{ loop.index0 }}], stack: 'stack0' }{% if not loop.last %},{% endif %}
            {% endfor %}
        ]
    },
    options: {
        plugins: { legend: { labels: { color: '#e4e6f0', boxWidth: 12 }, position: 'bottom' }, tooltip: { mode: 'index', intersect: false } },
        scales: {
            x: { stacked: true, ticks: { color: '#8b90a8', maxTicksLimit: 14 }, grid: { color: '#2e3348' } },
            y: { stacked: true, ticks: { color: '#8b90a8' }, grid: { color: '#2e3348' }, beginAtZero: true }
        }
    }
});
{% endif %}

{% set mb = model_breakdown|default([]) %}
{% if mb|length > 0 %}
const dOpts = { plugins: { legend: { labels: { color: '#e4e6f0', boxWidth: 12 }, position: 'bottom' } } };
new Chart(document.getElementById('chartKTokMod'), { type:'doughnut', data:{labels:{{ mb|map(v => v.model_alias)|json_encode|raw }},datasets:[{data:{{ mb|map(v => v.tokens)|json_encode|raw }},backgroundColor:colors}]}, options:dOpts });
new Chart(document.getElementById('chartKCostMod'), { type:'doughnut', data:{labels:{{ mb|map(v => v.model_alias)|json_encode|raw }},datasets:[{data:{{ mb|map(v => v.cost)|json_encode|raw }},backgroundColor:colors}]}, options:dOpts });
new Chart(document.getElementById('chartKReqMod'), { type:'doughnut', data:{labels:{{ mb|map(v => v.model_alias)|json_encode|raw }},datasets:[{data:{{ mb|map(v => v.requests)|json_encode|raw }},backgroundColor:colors}]}, options:dOpts });
{% endif %}
</script>
{% endblock %}
