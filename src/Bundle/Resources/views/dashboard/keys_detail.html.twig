{% extends "@AIGateway/dashboard/base.html.twig" %}
{% import "@AIGateway/dashboard/base.html.twig" as dash %}

{% block title %}AIGateway Dashboard — Key {{ key.name }}{% endblock %}

{% block head %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
{% endblock %}

{% block content %}
<div style="display:flex;justify-content:space-between;align-items:center">
    <h1 class="page-title">Key: {{ key.name }}</h1>
    <div style="display:flex;gap:12px;align-items:center">
        {% if key.enabled %}
        <span class="badge badge-green">active</span>
        <a href="{{ dash.turl('/dashboard/keys/' ~ key.id ~ '/edit', dashboard_token|default('')) }}" class="btn btn-primary" style="padding:6px 16px;font-size:13px">Edit</a>
        <form method="POST" action="{{ dash.turl('/dashboard/keys/' ~ key.id ~ '/revoke', dashboard_token|default('')) }}" style="display:inline" onsubmit="return confirm('Revoke this key? It cannot be undone.')">
            <button type="submit" class="btn btn-danger" style="padding:6px 16px;font-size:13px">Revoke</button>
        </form>
        {% else %}
        <span class="badge badge-red">revoked</span>
        <a href="{{ dash.turl('/dashboard/keys/' ~ key.id ~ '/edit', dashboard_token|default('')) }}" class="btn btn-primary" style="padding:6px 16px;font-size:13px">Edit</a>
        {% endif %}
    </div>
</div>

<div class="grid grid-4">
    <div class="card">
        <h3>Total Requests</h3>
        <div class="value blue">{{ key_stats.requests|number_format }}</div>
    </div>
    <div class="card">
        <h3>Total Tokens</h3>
        <div class="value green">{{ key_stats.tokens|number_format }}</div>
    </div>
    <div class="card">
        <h3>Total Cost</h3>
        <div class="value yellow">${{ key_stats.cost|number_format(4) }}</div>
    </div>
    <div class="card">
        <h3>Errors</h3>
        <div class="value {% if key_stats.errors > 0 %}red{% else %}green{% endif %}">{{ key_stats.errors }}</div>
    </div>
</div>

<div class="grid grid-2">
    <div class="card">
        <h3>Details</h3>
        <dl class="def-list">
            <dt>ID</dt>
            <dd class="mono">{{ key.id }}</dd>
            <dt>Prefix</dt>
            <dd class="mono">{{ key.tokenPrefix }}...</dd>
            <dt>Team</dt>
            <dd>{% if team %}<a href="{{ dash.turl('/dashboard/teams/' ~ team.id, dashboard_token|default('')) }}">{{ team.name }}</a>{% else %}<span style="color:var(--text2)">none (standalone)</span>{% endif %}</dd>
            <dt>Enabled</dt>
            <dd>{{ key.enabled ? 'yes' : 'no' }}</dd>
            <dt>Expired</dt>
            <dd>{{ key.isExpired() ? 'yes' : 'no' }}</dd>
            <dt>Created</dt>
            <dd>{{ key.createdAt|date('Y-m-d H:i:s') }}</dd>
        </dl>
    </div>

    <div class="card">
        <h3>Usage Today</h3>
        {% if usage_today %}
        <dl class="def-list">
            <dt>Requests</dt>
            <dd>{{ usage_today.requests }}</dd>
            <dt>Tokens</dt>
            <dd>{{ usage_today.tokens|number_format }}</dd>
            <dt>Cost</dt>
            <dd style="color:var(--yellow)">${{ usage_today.costUsd|number_format(6) }}</dd>
        </dl>
        {% else %}
        <p style="color:var(--text2)">No usage recorded today.</p>
        {% endif %}
    </div>
</div>

{% if model_breakdown|length > 0 %}
<div class="section">
    <h2>Model Breakdown</h2>
    <div class="card" style="padding:0;overflow:hidden">
        <table>
            <thead><tr><th>Model</th><th>Requests</th><th>Tokens</th><th>Cost</th></tr></thead>
            <tbody>
            {% for m in model_breakdown %}
            <tr>
                <td><strong>{{ m.model_alias }}</strong></td>
                <td>{{ m.requests|number_format }}</td>
                <td>{{ m.tokens|number_format }}</td>
                <td style="color:var(--yellow)">${{ m.cost|number_format(4) }}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{% if recent_logs|length > 0 %}
<div class="section">
    <h2>Recent Requests ({{ key_stats.requests }} total)</h2>
    <div class="card" style="padding:0;overflow:hidden">
        <table>
            <thead>
                <tr><th>Time</th><th>Model</th><th>Provider</th><th>Tokens</th><th>Cost</th><th>Duration</th><th>Status</th></tr>
            </thead>
            <tbody>
            {% for log in recent_logs %}
            <tr>
                <td class="mono" style="font-size:12px">{{ log.created_at|date('Y-m-d H:i') }}</td>
                <td>{{ log.model_alias }}</td>
                <td>{{ log.provider }}</td>
                <td>{{ log.total_tokens|number_format }} <span style="color:var(--text2);font-size:12px">({{ log.prompt_tokens }}↑ {{ log.completion_tokens }}↓)</span></td>
                <td style="color:var(--yellow)">${{ log.cost_usd|number_format(6) }}</td>
                <td>{{ log.duration_ms|number_format(1) }}ms</td>
                <td>
                    {% if log.cached %}
                    <span class="badge badge-green">cached</span>
                    {% elseif log.status_code >= 400 %}
                    <span class="badge badge-red">{{ log.status_code }}</span>
                    {% else %}
                    <span class="badge badge-green">{{ log.status_code }}</span>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

<div class="section">
    <h2>Effective Rules {% if team %}<span style="color:var(--text2);font-size:14px;font-weight:normal">(what actually applies)</span>{% endif %}</h2>
    <div class="card">
        <dl class="def-list">
            <dt>Budget / Day</dt>
            <dd>
                {% if effective_rules.budgetPerDay is not null %}
                    ${{ effective_rules.budgetPerDay|number_format(2) }}
                {% else %}
                    <span style="color:var(--text2)">unlimited</span>
                {% endif %}
            </dd>
            <dt>Budget / Month</dt>
            <dd>
                {% if effective_rules.budgetPerMonth is not null %}
                    ${{ effective_rules.budgetPerMonth|number_format(2) }}
                {% else %}
                    <span style="color:var(--text2)">unlimited</span>
                {% endif %}
            </dd>
            <dt>Rate Limit</dt>
            <dd>
                {% if effective_rules.rateLimitPerMinute is not null %}
                    {{ effective_rules.rateLimitPerMinute }} req/min
                {% else %}
                    <span style="color:var(--text2)">unlimited</span>
                {% endif %}
            </dd>
            <dt>Models</dt>
            <dd>
                {% if effective_rules.models is not null %}
                    {{ effective_rules.models|join(', ') }}
                {% else %}
                    all
                {% endif %}
            </dd>
        </dl>
    </div>
</div>

{% if team %}
<div class="section">
    <h2>Breakdown</h2>
    <div class="grid grid-2">
        <div class="card">
            <h3>Team Rules <span style="color:var(--text2);font-weight:normal">({{ team.name }})</span></h3>
            <dl class="def-list">
                <dt>Budget / Day</dt>
                <dd>{{ team.rules.budgetPerDay is not null ? '$' ~ team.rules.budgetPerDay|number_format(2) : '<span style="color:var(--text2)">unlimited</span>' }}</dd>
                <dt>Budget / Month</dt>
                <dd>{{ team.rules.budgetPerMonth is not null ? '$' ~ team.rules.budgetPerMonth|number_format(2) : '<span style="color:var(--text2)">unlimited</span>' }}</dd>
                <dt>Rate Limit</dt>
                <dd>{{ team.rules.rateLimitPerMinute is not null ? team.rules.rateLimitPerMinute ~ ' req/min' : '<span style="color:var(--text2)">unlimited</span>' }}</dd>
                <dt>Models</dt>
                <dd>{{ team.rules.models is not null ? team.rules.models|join(', ') : 'all' }}</dd>
            </dl>
        </div>
        <div class="card">
            <h3>Key Overrides {% if not has_own_overrides %}<span style="color:var(--text2);font-weight:normal">(inherits everything)</span>{% endif %}</h3>
            {% if has_own_overrides %}
            <dl class="def-list">
                <dt>Budget / Day</dt>
                <dd>{{ key.overrides.budgetPerDay is not null ? '$' ~ key.overrides.budgetPerDay|number_format(2) : '<span style="color:var(--text2)">inherits</span>' }}</dd>
                <dt>Budget / Month</dt>
                <dd>{{ key.overrides.budgetPerMonth is not null ? '$' ~ key.overrides.budgetPerMonth|number_format(2) : '<span style="color:var(--text2)">inherits</span>' }}</dd>
                <dt>Rate Limit</dt>
                <dd>{{ key.overrides.rateLimitPerMinute is not null ? key.overrides.rateLimitPerMinute ~ ' req/min' : '<span style="color:var(--text2)">inherits</span>' }}</dd>
                <dt>Models</dt>
                <dd>{{ key.overrides.models is not null ? key.overrides.models|join(', ') : '<span style="color:var(--text2)">inherits</span>' }}</dd>
            </dl>
            {% else %}
            <p style="color:var(--text2)">No overrides — this key inherits all rules from team <strong>{{ team.name }}</strong>.</p>
            {% endif %}
        </div>
    </div>
</div>
{% endif %}
{% endblock %}
