{% extends "@AIGateway/dashboard/base.html.twig" %}
{% import "@AIGateway/dashboard/base.html.twig" as dash %}

{% block title %}AIGateway Dashboard — Team {{ team.name }}{% endblock %}

{% block head %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
{% endblock %}

{% block content %}
<div style="display:flex;justify-content:space-between;align-items:center">
    <h1 class="page-title">Team: {{ team.name }}</h1>
    <a href="{{ dash.turl('/dashboard/teams/' ~ team.id ~ '/edit', dashboard_token|default('')) }}" class="btn btn-primary" style="padding:6px 16px;font-size:13px">Edit</a>
</div>

<div class="grid grid-4">
    <div class="card">
        <h3>Total Requests</h3>
        <div class="value blue">{{ team_stats.requests|number_format }}</div>
    </div>
    <div class="card">
        <h3>Total Tokens</h3>
        <div class="value green">{{ team_stats.tokens|number_format }}</div>
    </div>
    <div class="card">
        <h3>Total Cost</h3>
        <div class="value yellow">${{ team_stats.cost|number_format(4) }}</div>
    </div>
    <div class="card">
        <h3>Errors</h3>
        <div class="value {% if team_stats.errors > 0 %}red{% else %}green{% endif %}">{{ team_stats.errors }}</div>
    </div>
</div>

<div class="section">
    <h2>Usage Over Time (30 days)</h2>
    <div class="card">
        <canvas id="chartDailyUsage" height="100"></canvas>
    </div>
</div>

<div class="grid grid-2">
    <div class="card">
        <h3>Cost by Model</h3>
        <canvas id="chartModelCost" height="200"></canvas>
    </div>
    <div class="card">
        <h3>Cost by Provider</h3>
        <canvas id="chartProviderCost" height="200"></canvas>
    </div>
</div>

<div class="card">
    <dl class="def-list">
        <dt>ID</dt>
        <dd class="mono">{{ team.id }}</dd>
        <dt>Parent</dt>
        <dd>
            {% if parent_team %}
                <a href="{{ dash.turl('/dashboard/teams/' ~ parent_team.id, dashboard_token|default('')) }}">{{ parent_team.name }}</a>
            {% else %}
                root
            {% endif %}
        </dd>
        <dt>Created</dt>
        <dd>{{ team.createdAt|date('Y-m-d H:i:s') }}</dd>
    </dl>
</div>

<div class="section">
    <h2>Rules</h2>
    <div class="card">
        <dl class="def-list">
            <dt>Budget / Day</dt>
            <dd>{{ team.rules.budgetPerDay ? '$' ~ team.rules.budgetPerDay|number_format(2) : 'none' }}</dd>
            <dt>Budget / Month</dt>
            <dd>{{ team.rules.budgetPerMonth ? '$' ~ team.rules.budgetPerMonth|number_format(2) : 'none' }}</dd>
            <dt>Rate Limit</dt>
            <dd>{{ team.rules.rateLimitPerMinute ? team.rules.rateLimitPerMinute ~ ' req/min' : 'none' }}</dd>
            <dt>Models</dt>
            <dd>{{ team.rules.models ? team.rules.models|join(', ') : 'all' }}</dd>
        </dl>
    </div>
</div>

{% if ancestry|length > 1 %}
<div class="section">
    <h2>Ancestry (root → this team)</h2>
    <div class="card">
        {% for a in ancestry %}
        <div style="padding:8px 0;{% if not loop.last %}border-bottom:1px solid var(--border){% endif %}">
            <span style="color:var(--text2);margin-right:12px">{{ loop.index }}.</span>
            {% if a.id == team.id %}
            <strong>{{ a.name }}</strong> <span class="badge badge-green" style="margin-left:8px">current</span>
            {% else %}
            <a href="{{ dash.turl('/dashboard/teams/' ~ a.id, dashboard_token|default('')) }}">{{ a.name }}</a>
            {% endif %}
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{% if team_model_breakdown|length > 0 %}
<div class="section">
    <h2>Models Used</h2>
    <div class="card" style="padding:0;overflow:hidden">
        <table>
            <thead><tr><th>Model</th><th>Requests</th><th>Tokens</th><th>Cost</th></tr></thead>
            <tbody>
            {% for alias, data in team_model_breakdown %}
            <tr>
                <td><a href="{{ dash.turl('/dashboard/models/' ~ alias, dashboard_token|default('')) }}"><strong>{{ alias }}</strong></a></td>
                <td>{{ data.requests|number_format }}</td>
                <td>{{ data.tokens|number_format }}</td>
                <td style="color:var(--yellow)">${{ data.cost|number_format(4) }}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{% if team_provider_breakdown|length > 0 %}
<div class="section">
    <h2>Providers Used</h2>
    <div class="card" style="padding:0;overflow:hidden">
        <table>
            <thead><tr><th>Provider</th><th>Requests</th><th>Cost</th></tr></thead>
            <tbody>
            {% for prov, data in team_provider_breakdown %}
            <tr>
                <td><a href="{{ dash.turl('/dashboard/providers/' ~ prov, dashboard_token|default('')) }}"><strong>{{ prov }}</strong></a></td>
                <td>{{ data.requests|number_format }}</td>
                <td style="color:var(--yellow)">${{ data.cost|number_format(4) }}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{% if member_usage|length > 0 %}
<div class="section">
    <h2>Member Usage (sorted by cost)</h2>
    <div class="card" style="padding:0;overflow:hidden">
        <table>
            <thead><tr><th>Key</th><th>Requests</th><th>Tokens</th><th>Cost</th></tr></thead>
            <tbody>
            {% for m in member_usage %}
            <tr>
                <td><a href="{{ dash.turl('/dashboard/keys/' ~ m.key_id, dashboard_token|default('')) }}">{{ m.key_name }}</a></td>
                <td>{{ m.requests|number_format }}</td>
                <td>{{ m.tokens|number_format }}</td>
                <td style="color:var(--yellow)">${{ m.cost|number_format(4) }}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{% if team_keys|length > 0 %}
<div class="section">
    <h2>Keys in this team ({{ team_keys|length }})</h2>
    <div class="card" style="padding:0;overflow:hidden">
        <table>
            <thead><tr><th>Name</th><th>Prefix</th><th>Status</th><th></th></tr></thead>
            <tbody>
            {% for k in team_keys %}
            <tr>
                <td><a href="{{ dash.turl('/dashboard/keys/' ~ k.id, dashboard_token|default('')) }}">{{ k.name }}</a></td>
                <td class="mono">{{ k.tokenPrefix }}...</td>
                <td>
                    {% if k.enabled %}
                    <span class="badge badge-green">active</span>
                    {% else %}
                    <span class="badge badge-red">revoked</span>
                    {% endif %}
                </td>
                <td><a href="{{ dash.turl('/dashboard/keys/' ~ k.id, dashboard_token|default('')) }}">view →</a></td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{% if team_stats.requests == 0 %}
<div class="empty">
    <h3>No usage data yet</h3>
    <p>Send requests using keys from this team to see analytics.</p>
</div>
{% endif %}
{% endblock %}

{% block scripts %}
{% if team_daily_usage|length > 0 %}
<script>
new Chart(document.getElementById('chartDailyUsage'), {
    type: 'bar',
    data: {
        labels: {{ team_daily_usage|map(d => d.date)|json_encode|raw }},
        datasets: [{
            label: 'Requests',
            data: {{ team_daily_usage|map(d => d.requests)|json_encode|raw }},
            backgroundColor: '#6366f1',
            yAxisID: 'y'
        }, {
            label: 'Cost (USD)',
            data: {{ team_daily_usage|map(d => d.cost)|json_encode|raw }},
            backgroundColor: '#f59e0b',
            yAxisID: 'y1'
        }]
    },
    options: {
        plugins: { legend: { labels: { color: '#e4e6f0' } } },
        scales: {
            x: { ticks: { color: '#8b90a8', maxTicksLimit: 10 }, grid: { color: '#2e3348' } },
            y: { ticks: { color: '#8b90a8' }, grid: { color: '#2e3348' }, position: 'left' },
            y1: { ticks: { color: '#f59e0b' }, grid: { display: false }, position: 'right' }
        }
    }
});
</script>
{% endif %}

{% if team_model_breakdown|length > 0 %}
<script>
new Chart(document.getElementById('chartModelCost'), {
    type: 'doughnut',
    data: {
        labels: {{ team_model_breakdown|keys|json_encode|raw }},
        datasets: [{
            data: {{ team_model_breakdown|map(v => v.cost)|json_encode|raw }},
            backgroundColor: ['#6366f1','#3b82f6','#22c55e','#f59e0b','#ef4444','#8b5cf6','#ec4899','#14b8a6','#f97316','#a855f7']
        }]
    },
    options: { plugins: { legend: { labels: { color: '#e4e6f0' }, position: 'bottom' } } }
});
</script>
{% endif %}

{% if team_provider_breakdown|length > 0 %}
<script>
new Chart(document.getElementById('chartProviderCost'), {
    type: 'doughnut',
    data: {
        labels: {{ team_provider_breakdown|keys|json_encode|raw }},
        datasets: [{
            data: {{ team_provider_breakdown|map(v => v.cost)|json_encode|raw }},
            backgroundColor: ['#3b82f6','#22c55e','#f59e0b','#ef4444','#8b5cf6','#ec4899']
        }]
    },
    options: { plugins: { legend: { labels: { color: '#e4e6f0' }, position: 'bottom' } } }
});
</script>
{% endif %}
{% endblock %}
