{% extends "@AIGateway/dashboard/base.html.twig" %}

{% block title %}AIGateway Dashboard — Team {{ team.name }}{% endblock %}

{% block content %}
<h1 class="page-title">Team: {{ team.name }}</h1>

<div class="card">
    <dl class="def-list">
        <dt>ID</dt>
        <dd class="mono">{{ team.id }}</dd>
        <dt>Parent</dt>
        <dd>{{ team.parentId ?? 'root' }}</dd>
        <dt>Created</dt>
        <dd>{{ team.createdAt|date('Y-m-d H:i:s') }}</dd>
    </dl>
</div>

<div class="section">
    <h2>Rules</h2>
    <div class="card">
        <dl class="def-list">
            <dt>Budget / Day</dt>
            <dd>{{ team.rules.budgetPerDay ? '$' ~ team.rules.budgetPerDay|number_format(2) : 'none' }}</dd>
            <dt>Budget / Month</dt>
            <dd>{{ team.rules.budgetPerMonth ? '$' ~ team.rules.budgetPerMonth|number_format(2) : 'none' }}</dd>
            <dt>Rate Limit</dt>
            <dd>{{ team.rules.rateLimitPerMinute ? team.rules.rateLimitPerMinute ~ ' req/min' : 'none' }}</dd>
            <dt>Models</dt>
            <dd>{{ team.rules.models ? team.rules.models|join(', ') : 'all' }}</dd>
        </dl>
    </div>
</div>

{% if ancestry|length > 1 %}
<div class="section">
    <h2>Ancestry (root → this team)</h2>
    <div class="card">
        {% for a in ancestry %}
        <div style="padding:8px 0;{% if not loop.last %}border-bottom:1px solid var(--border){% endif %}">
            <span style="color:var(--text2);margin-right:12px">{{ loop.index }}.</span>
            {% if a.id == team.id %}
            <strong>{{ a.name }}</strong> <span class="badge badge-green" style="margin-left:8px">current</span>
            {% else %}
            <a href="/dashboard/teams/{{ a.id }}">{{ a.name }}</a>
            {% endif %}
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{% if team_keys|length > 0 %}
<div class="section">
    <h2>Keys in this team ({{ team_keys|length }})</h2>
    <div class="card" style="padding:0;overflow:hidden">
        <table>
            <thead><tr><th>Name</th><th>Prefix</th><th>Status</th><th></th></tr></thead>
            <tbody>
            {% for k in team_keys %}
            <tr>
                <td><a href="/dashboard/keys/{{ k.id }}">{{ k.name }}</a></td>
                <td class="mono">{{ k.tokenPrefix }}...</td>
                <td>
                    {% if k.enabled %}
                    <span class="badge badge-green">active</span>
                    {% else %}
                    <span class="badge badge-red">revoked</span>
                    {% endif %}
                </td>
                <td><a href="/dashboard/keys/{{ k.id }}">view →</a></td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
