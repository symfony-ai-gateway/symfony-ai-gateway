{% extends "@AIGateway/dashboard/base.html.twig" %}
{% import "@AIGateway/dashboard/base.html.twig" as dash %}

{% block title %}AIGateway Dashboard — Edit Key: {{ key.name }}{% endblock %}

{% block content %}
<h1 class="page-title">Edit API Key: {{ key.name }}</h1>

<div class="card">
    <form method="POST">
        <div class="def-list" style="grid-template-columns:160px 1fr;gap:16px">
            <dt><label for="name">Name</label></dt>
            <dd><input type="text" id="name" name="name" required value="{{ key.name }}" style="width:100%;padding:8px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text)"></dd>

            <dt><label for="team_id">Team</label></dt>
            <dd>
                <select id="team_id" name="team_id" style="width:100%;padding:8px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text)">
                    <option value="">— none (standalone key) —</option>
                    {% for t in teams %}
                    <option value="{{ t.id }}" {{ key.teamId == t.id ? 'selected' : '' }}>{{ t.name }}</option>
                    {% endfor %}
                </select>
            </dd>
        </div>

        {% if current_team %}
        <div style="margin:20px 0 0;padding:16px;background:var(--surface2);border-radius:8px;border-left:3px solid var(--accent)">
            <strong style="color:var(--accent)">Team limits ({{ current_team.name }})</strong> — overrides must be ≤ these values.
            <span style="display:block;margin-top:8px;color:var(--text2);font-size:13px">
                Budget: {{ current_team.rules.budgetPerDay is not null ? '$' ~ current_team.rules.budgetPerDay|number_format(2) ~ '/day' : 'unlimited' }}
                &middot; Rate: {{ current_team.rules.rateLimitPerMinute is not null ? current_team.rules.rateLimitPerMinute ~ ' req/min' : 'unlimited' }}
                &middot; Models: {{ current_team.rules.models is not null ? current_team.rules.models|join(', ') : 'all' }}
            </span>
        </div>
        {% endif %}

        <div class="def-list" style="grid-template-columns:160px 1fr;gap:16px;margin-top:20px">
            <dt><label for="models">Models</label></dt>
            <dd>
                <input type="text" id="models" name="models" value="{{ key.overrides is not null and key.overrides.models ? key.overrides.models|join(',') : '' }}" placeholder="{{ model_aliases|join(', ') }}" style="width:100%;padding:8px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text)">
                <span style="color:var(--text2);font-size:12px">Comma-separated, empty = inherit from team</span>
            </dd>

            <dt><label for="budget_per_day">Budget / Day (USD)</label></dt>
            <dd>
                <input type="number" step="0.01" id="budget_per_day" name="budget_per_day" value="{{ key.overrides is not null and key.overrides.budgetPerDay is not null ? key.overrides.budgetPerDay : '' }}" placeholder="{{ current_team.rules.budgetPerDay ?? 'unlimited' }}" style="width:100%;padding:8px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text)">
                <span style="color:var(--text2);font-size:12px">Empty = inherit{% if current_team and current_team.rules.budgetPerDay %} (max: ${{ current_team.rules.budgetPerDay|number_format(2) }}){% endif %}</span>
            </dd>

            <dt><label for="rate_limit">Rate Limit (req/min)</label></dt>
            <dd>
                <input type="number" id="rate_limit" name="rate_limit" value="{{ key.overrides is not null and key.overrides.rateLimitPerMinute is not null ? key.overrides.rateLimitPerMinute : '' }}" placeholder="{{ current_team.rules.rateLimitPerMinute ?? 'unlimited' }}" style="width:100%;padding:8px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text)">
                <span style="color:var(--text2);font-size:12px">Empty = inherit{% if current_team and current_team.rules.rateLimitPerMinute %} (max: {{ current_team.rules.rateLimitPerMinute }}){% endif %}</span>
            </dd>
        </div>

        <div style="margin-top:24px;display:flex;gap:12px">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="{{ dash.turl('/dashboard/keys/' ~ key.id, dashboard_token|default('')) }}" class="btn" style="background:var(--surface2)">Cancel</a>
        </div>
    </form>
</div>
{% endblock %}
