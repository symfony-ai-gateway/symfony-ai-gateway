{
    "name": "ai-gateway/ai-gateway-bundle",
    "description": "PHP AI Gateway — Unified LLM proxy with fallback, caching, rate limiting and cost tracking",
    "type": "symfony-bundle",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "doctrine/dbal": "^4.4",
        "psr/event-dispatcher": "^1.0",
        "psr/log": "^3.0",
        "symfony/ai-anthropic-platform": "^0.8.1",
        "symfony/ai-bundle": "^0.8.0",
        "symfony/ai-chat": "^0.8.0",
        "symfony/ai-generic-platform": "^0.8.0",
        "symfony/ai-open-ai-platform": "^0.8.0",
        "symfony/ai-platform": "^0.8.1",
        "symfony/clock": "^7.4 || ^8.0",
        "symfony/config": "^7.0 || ^8.0",
        "symfony/console": "^7.0 || ^8.0",
        "symfony/dependency-injection": "^7.0 || ^8.0",
        "symfony/event-dispatcher": "^7.0 || ^8.0",
        "symfony/framework-bundle": "^7.0 || ^8.0",
        "symfony/http-client": "^7.0 || ^8.0",
        "symfony/http-foundation": "^7.0 || ^8.0",
        "symfony/http-kernel": "^7.0 || ^8.0",
        "symfony/property-access": "^7.4 || ^8.0",
        "symfony/property-info": "^7.4 || ^8.0",
        "symfony/routing": "^7.0 || ^8.0",
        "symfony/serializer": "^7.4 || ^8.0",
        "symfony/twig-bundle": "^7.0 || ^8.0",
        "symfony/type-info": "^7.4 || ^8.0",
        "symfony/uid": "^7.4 || ^8.0",
        "symfony/yaml": "^7.0 || ^8.0",
        "twig/twig": "^3.24"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.12",
        "phpstan/phpstan-deprecation-rules": "^1.2",
        "phpstan/phpstan-strict-rules": "^1.6",
        "friendsofphp/php-cs-fixer": "^3.64"
    },
    "autoload": {
        "psr-4": {
            "AIGateway\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AIGateway\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-html coverage/",
        "stan": "phpstan analyse --memory-limit=512M",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": [
            "@stan",
            "@cs:check",
            "@test"
        ]
    },
    "extra": {
        "symfony": {
            "bundle": "AIGateway\\Bundle\\AIGatewayBundle"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": false
    },
    "keywords": ["ai", "llm", "gateway", "proxy", "openai", "anthropic", "php", "symfony"],
    "authors": [
        {
            "name": "Mathieu BERNARD",
            "email": "mbernard@etixio.com"
        }
    ],
    "support": {
        "issues": "https://github.com/symfony-ai-gateway/symfony-ai-gateway/issues",
        "source": "https://github.com/symfony-ai-gateway/symfony-ai-gateway"
    }
}
