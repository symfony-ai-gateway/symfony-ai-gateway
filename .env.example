# ── Provider API Keys ──────────────────────────────────────────────────────────
# At least one provider is required. Fill in the keys for the providers you use.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
AZURE_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=prod
APP_DEBUG=0
APP_KERNEL_CLASS=AIGateway\Standalone\StandaloneKernel

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Set a token to protect the dashboard (optional but recommended)
# Access via /dashboard?token=YOUR_TOKEN
# AI_GATEWAY_DASHBOARD_TOKEN=my-secret-token
